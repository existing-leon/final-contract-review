APP_NAME=contract-review
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=contract_review

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 审批系统接入
APPROVAL_BASE_URL=https://approval.example.com
APPROVAL_API_KEY=

# 演示模式：True 时审批系统接口返回 mock 数据（开箱可演示，无需真实审批系统）
MOCK_APPROVAL=True

# 附件本地存储
ATTACHMENT_DIR=./storage

# 示例合同目录（mock 附件的真实 PDF 来源）
SAMPLES_DIR=./samples

# OCR 版面分析：True 时扫描件优先用 PaddleOCR PP-Structure 做版面+表格还原
OCR_USE_LAYOUT=True

# LLM（字段提取；OpenAI 兼容接口，留空则走正则提取）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=60
# False=忽略系统/环境代理直连（dashscope 国内推荐；若必须走代理改为 True）
LLM_TRUST_ENV=False
LLM_MAX_RETRIES=3
